NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Supabase JWT 署名鍵 (ES256, P-256 ECDSA, PKCS#8 PEM)。
# src/lib/supabase-jwt.ts が per-request の tenant_id 付き JWT を発行し、
# RLS ポリシーが claim 経由でテナント分離を強制する。
#
# 初回セットアップ:
#   1. ローカルで keypair 生成
#        openssl ecparam -name prime256v1 -genkey -noout \
#          | openssl pkcs8 -topk8 -nocrypt -out es256-private.pem
#   2. Supabase Dashboard → Settings → API → JWT Keys → Create new Standby Key
#      → "Import an existing private key" をチェック → es256-private.pem の内容を貼る
#   3. その同じ PEM を以下にセット (改行は `\n` でも実改行 with クォートでも可)
SUPABASE_JWT_PRIVATE_KEY=

# 上記 private key に対応する Supabase 側 JWT signing key の Key ID (kid)。
# Dashboard → Settings → API → JWT Keys で確認できる UUID。
# Realtime の JWT verify は header.kid が JWKS と完全一致することを要求するため、
# private key と kid は必ずペアで管理する（rotation のたびに両方更新）。
SUPABASE_JWT_KID=

# Optional: override tenant resolution.
# Production / Preview では未設定が推奨（src/lib/tenant.ts が Host ヘッダから
# 動的に slug を抽出する）。ローカル開発で別テナントを見たい時のみ設定する。
# Values: `union` (generic demo) | `sanshin` (三信産業) | (future tenants)
# TENANT_SLUG=sanshin

# Google Maps Platform — Places (Autocomplete) + Geocoding + Maps JS
# 未設定時は cart の住所入力が通常の text input にフォールバックする
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Maps の Map ID (任意)。設定時は AdvancedMarkerElement が有効になる。
# 未設定時は従来の google.maps.Marker にフォールバック（コンソール警告が出るが動作する）。
# Cloud Console → Google Maps Platform → Map Management → Create new Map ID で発行。
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Resend — メール通知（受付/承認/却下/出荷/管理者向け新規受付）
# 未設定の場合はメール送信をスキップし email_logs に "skipped" として記録する
RESEND_API_KEY=
# 認証済みドメインの送信元アドレス。未設定時は Resend のテストドメイン onboarding@resend.dev を使用
EMAIL_FROM=
